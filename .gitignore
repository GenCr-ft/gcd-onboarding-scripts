# Gencraft Studio - Standard .gitignore (v1.0)
# This file is part of gct-repo-template-standard and should be the base for all new repositories.

# Node.js
# Dependencies are managed by package managers, do not commit them.
node_modules/
# Build output
dist/
build/
# Logs
*.log
npm-debug.log*
yarn-error.log*

# Python
# Cache and compiled files
__pycache__/
*.py[cod]
# Virtual environments
.venv/
venv/
env/

# Sensitive Environment Variables
# NEVER commit .env files. Use a .env.example as a template if needed.
.env
.env.local
.env.*.local

# OS & Editor Specific
# macOS
.DS_Store
# Vim
*~
*.swp
# VSCode
.vscode/

# Java (for completeness)
*.class
*.jar
