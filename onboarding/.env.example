# G@FT.ai Studio Developer Onboarding - Environment Variable Overrides
# Copy this file to ".env" in the same directory as gftai_onboarding.sh to use it.
# Lines starting with # are comments. Remove # from a line to activate the override.

# --- General Configuration ---
# Organization Name on GitHub (default is "GenCr-ft")
# GFTAI_ORG_NAME_OVERRIDE="GenCr-ft"

# Parent directory where your workspace and repositories will be cloned
# Defaults to ${HOME}/gftai_studio_workspace
# GFTAI_WORKSPACE_PARENT_DIR_OVERRIDE="${HOME}/my_custom_gft_workspace"

# Filename for the VS Code workspace file to be created within the parent directory
# Defaults to ${GFTAI_ORG_NAME}.code-workspace (e.g., GenCr-ft.code-workspace)
# GFTAI_VSCODE_WORKSPACE_FILENAME_OVERRIDE="my_gencraft_projects.code-workspace"

# --- Git Configuration ---
# Your full name for Git commits. If not set, the script will prompt you.
# GIT_USER_NAME_OVERRIDE="Votre Nom Complet"

# Your email for Git commits (should match a verified email on your GitHub account).
# If not set, the script will prompt you.
# GIT_USER_EMAIL_OVERRIDE="votre.email@example.com"

# Default branch name for new repositories (Studio standard is 'main')
# GIT_DEFAULT_BRANCH_NAME_OVERRIDE="main"

# --- Automation Flags (set to true or false) ---
# Skip all automatic tool installations (git, gh, nvm, node, pyenv, python, docker, pre-commit, etc.)
# AUTO_INSTALL_TOOLS_OVERRIDE=false

# Skip automatic SSH key generation if you have one you prefer to use / set up manually
# AUTO_GENERATE_SSH_KEY_OVERRIDE=false

# Skip attempting to add the SSH public key to your GitHub account via 'gh'
# AUTO_ADD_SSH_KEY_TO_GITHUB_OVERRIDE=false

# Skip cloning all default studio repositories (the script default is to clone all ~40 repos)
# AUTO_CLONE_REPOS_OVERRIDE=false

# Skip creating the VS Code .code-workspace file
# AUTO_CREATE_WORKSPACE_OVERRIDE=false

# Skip installing recommended VS Code extensions
# AUTO_INSTALL_VSCODE_EXTENSIONS_OVERRIDE=false

# Skip attempting to open VS Code at the end of the script
# AUTO_OPEN_VSCODE_OVERRIDE=false

# --- Repository Cloning ---
# To override the default list of repositories to clone, provide a space-separated string of repository names.
# The script default is to clone all ~40 repositories you provided.
# Example to clone only a few:
# GFTAI_REPOS_TO_CLONE_OVERRIDE="gcs-studio-handbook gcd-onboarding-scripts gcp-aethel-client"
# GFTAI_REPOS_TO_CLONE_OVERRIDE=""

# --- VS Code Extensions ---
# To override the list of VS Code extensions to install, provide a space-separated string of extension IDs.
# Example: VSCODE_EXTENSIONS_TO_INSTALL_OVERRIDE="ms-python.python eamodio.gitlens"
# If commented out or empty, the script's default extensive list will be used.
# VSCODE_EXTENSIONS_TO_INSTALL_OVERRIDE=""
