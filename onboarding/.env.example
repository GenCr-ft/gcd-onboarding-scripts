# .env - Example Configuration File for G@FT.ai Onboarding Script
#
# Instructions:
# 1. Save this content in a file named exactly ".env" (note the leading dot).
# 2. Place this .env file in the SAME DIRECTORY where you run the gftai_onboarding.sh script.
#    Alternatively, you can place it at ~/.config/gftai_onboarding/.env (the script checks both locations).
# 3. Uncomment and modify the lines below to set your desired configurations.
# 4. Lines starting with # are comments and will be ignored.
# 5. Values can be enclosed in double quotes if they contain spaces, but it's not strictly necessary for simple values.

# --- GitHub Organization ---
# GFTAI_ORG_NAME="GenCr-ft"

# --- Workspace Directory Structure ---
# Parent directory where all your G@FT.ai projects will reside.
# Use ~ for your home directory.
# GFTAI_WORKSPACE_PARENT_DIR="~/gftai_dev_projects"

# Name of the subdirectory within GFTAI_WORKSPACE_PARENT_DIR where this organization's repos will be cloned.
# Defaults to the GFTAI_ORG_NAME if not set.
# GFTAI_PROJECTS_DIR_NAME="MyGencraftRepos"

# --- VS Code Workspace File ---
# Filename for the VS Code workspace file that will be generated.
# It will be created inside GFTAI_WORKSPACE_PARENT_DIR.
# GFTAI_VSCODE_WORKSPACE_FILENAME="my-gftai-workspace.code-workspace"

# --- Default Git User Configuration ---
# These values will be suggested when the script prompts for your Git user.name and user.email.
# If you set these, the script will still ask for confirmation before using them.
# GIT_USER_NAME_DEFAULT="your name"

# GIT_USER_EMAIL_DEFAULT="your.email@example.com"
