# G@FT.ai Studio Developer Onboarding - Environment Variable Overrides
# Copy this file to .env in the same directory as gftai_onboarding.sh to use it.
# Lines starting with # are comments.

# --- General Configuration ---
# GFTAI_ORG_NAME_OVERRIDE="YourGitHubOrgName" # Defaults to GenCr-ft
# GFTAI_WORKSPACE_PARENT_DIR_OVERRIDE="${HOME}/my_custom_workspace" # Defaults to ${HOME}/gftai_studio_workspace
# GFTAI_VSCODE_WORKSPACE_FILENAME_OVERRIDE="my-custom-studio.code-workspace" # Defaults to ${GFTAI_ORG_NAME}.code-workspace

# --- Git Configuration ---
# GIT_USER_NAME_OVERRIDE="Your Full Name" # Will be prompted if empty
# GIT_USER_EMAIL_OVERRIDE="your.email@example.com" # Will be prompted if empty
# GIT_DEFAULT_BRANCH_NAME_OVERRIDE="main" # Studio default is 'main'

# --- Automation Flags (true/false) ---
# AUTO_INSTALL_TOOLS_OVERRIDE=false # Skip all automatic tool installations
# AUTO_GENERATE_SSH_KEY_OVERRIDE=false # Skip SSH key generation if you have one
# AUTO_ADD_SSH_KEY_TO_GITHUB_OVERRIDE=false # Skip adding SSH key to GitHub via gh
# AUTO_CLONE_REPOS_OVERRIDE=false # Skip cloning all default repositories
# AUTO_CREATE_WORKSPACE_OVERRIDE=false # Skip VS Code workspace file creation
# AUTO_INSTALL_VSCODE_EXTENSIONS_OVERRIDE=false # Skip VS Code extension installation
# AUTO_OPEN_VSCODE_OVERRIDE=false # Skip opening VS Code at the end

# --- Repository Cloning ---
# To override the default list of repositories to clone, provide a space-separated string.
# Example: GFTAI_REPOS_TO_CLONE_OVERRIDE="gcs-studio-handbook gcd-onboarding-scripts gcp-aethel-client"
# If commented out or empty, the script's default list (all ~40 repos from Lug's list) will be used.
# GFTAI_REPOS_TO_CLONE_OVERRIDE=""

# --- VS Code Extensions ---
# To override the list of VS Code extensions, provide a space-separated string of extension IDs.
# Example: VSCODE_EXTENSIONS_TO_INSTALL_OVERRIDE="ms-python.python eamodio.gitlens"
# If commented out or empty, the script's default list will be used.
# VSCODE_EXTENSIONS_TO_INSTALL_OVERRIDE=""
